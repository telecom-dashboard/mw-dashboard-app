# Non-secret production configuration.
# Secrets (SECRET_KEY, DB_PASSWORD) are fetched from
# AWS Parameter Store at runtime via start.sh:
#   /nw-monitor/mvp/backend/secret_key
#   /nw-monitor/mvp/backend/db_password

APP_ENV=production
APP_DEBUG=false

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=network_ops_db
DB_USER=postgres
DB_PASSWORD=

ACCESS_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://your-domain.com/api
ALLOWED_ORIGINS=https://your-domain.com

# Optional one-time admin seed values used by deploy.sh.
SEED_ADMIN_USERNAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
